# Storage arrays for RPT / SoH Plotting
all_rpt_capacities, tp_EoL_list, tp_BoL_list = [], [], []
all_throughput_lists, por_xavg_BoL_list, por_xavg_EoL_list = [], [], []
all_soh_lists, all_cycle_lists = [], []

# Storage arrays for Continuous Degradation Line Graph
cont_tp_list, cont_lli_list = [], []
cont_lam_neg_list, cont_lam_pos_list = [], []
