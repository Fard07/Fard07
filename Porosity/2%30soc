pri_lam = [2.8e-06]
sec_lam = [2.5e-08]

# ─── Loop: run sim for each C‑rate ────────────────
for idx_c, (c_rate, n_cycle) in enumerate(zip(c_rates, cycles_per_simulation)):

    #eps_s = Si_vol_fracs
    #eps_p = total_AM_frac - eps_s

    model = pybamm.lithium_ion.DFN({
        "particle phases": ("2", "1"),
        "open-circuit potential": (("single", "current sigmoid"), "single"),
        "particle mechanics": ("swelling only", "swelling only"),  # Positive kept to 'none' to prevent crashing
        "loss of active material": ("stress-driven", "stress-driven"),
        "SEI": "solvent-diffusion limited",
        "SEI porosity change": "true",
        "particle": "Fickian diffusion",
        "cell geometry": "arbitrary",
        "lithium plating": "partially reversible",
        "lithium plating porosity change": "true",
    })

    parameter_values = pybamm.ParameterValues("Chen2020_composite")

    parameter_values.update({
        "Lithium plating transfer coefficient": 0.5,
        "Dead lithium decay constant [s-1]": 1e-4,
        "Primary: Maximum concentration in negative electrode [mol.m-3]": 28700,
        "Primary: Initial concentration in negative electrode [mol.m-3]": 23000,
        "Secondary: Initial concentration in negative electrode [mol.m-3]": 277000,
        "Secondary: Maximum concentration in negative electrode [mol.m-3]": 278000,
        "Positive electrode LAM constant proportional term [s-1]": 4e-07,#1.7778e-07,
        "Secondary: Negative electrode partial molar volume [m3.mol-1]": 1.20e-05,
        "Positive electrode partial molar volume [m3.mol-1]": 1.2e-06,

        "Primary: Negative electrode LAM constant proportional term [s-1]": 2.8e-06,
        "Secondary: Negative electrode LAM constant proportional term [s-1]": 3.5e-08,
        "Primary: Outer SEI solvent diffusivity [m2.s-1]": 2.5e-24,
        "Secondary: Outer SEI solvent diffusivity [m2.s-1]": 9.5e-22,
        "Primary: Dead lithium decay constant [s-1]": 4e-05,  # Reduced from 1e-06
        "Secondary: Dead lithium decay constant [s-1]":1e-05,  # Reduced from 1e-06

        #"Secondary: Negative electrode active material volume fraction": eps_s,
        #"Primary: Negative electrode active material volume fraction": eps_p,
    }, check_already_exists=False)

    # ─── DYNAMIC EXPERIMENT SETUP ───
    aging_cycle = [(
        f"Discharge at {c_rate}C until 2.5V",
        "Charge at 0.3C for 3600 seconds (3 minute period)",  # Partial 30% SoC Charge
    )]

    # Unified RPT: Starts at ~30%, tops off, measures, resets to 100%
    rpt_cycle = [(
        "Charge at 0.3C until 4.2V (3 minute period)",  # Step 0: Bring to 100%
        "Hold at 4.2V until C/100 (3 minute period)",  # Step 1: Saturate
        "Discharge at 0.1C until 2.5V",  # Step 2: MEASUREMENT (Shifted from Step 3 to Step 2)
        "Charge at 0.3C for 3600 seconds (3 minute period)",  # Step 3: Reset to 100% for next aging block
    )]

    # 1. Start immediately with 5 Aging Cycles
    experiment_plan = aging_cycle * 5

    # 2. Append the 1st RPT
    experiment_plan += rpt_cycle.copy()

    # 3. Calculate remaining cycles to simulate
    remaining_cycles = n_cycle - 5
    chunks = remaining_cycles // 100
    remainder = remaining_cycles % 100

    # 4. Append the rest in chunks of 100
    for _ in range(chunks):
        experiment_plan += aging_cycle * 100
        experiment_plan += rpt_cycle.copy()

    if remainder > 0:
        experiment_plan += aging_cycle * remainder
        experiment_plan += rpt_cycle.copy()

    experiment = pybamm.Experiment(experiment_plan, period="180 seconds")

    # Use robust CasADi solver to survive 3200 cycles
    sim = pybamm.Simulation(
        model,
        experiment=experiment,
        parameter_values=parameter_values,
        solver=pybamm.IDAKLUSolver(atol=1e-8, rtol=1e-6, options={"linear_solver": "SUNLinSol_KLU"}),
    )
    solution = sim.solve(calc_esoh=False)
    sol_list.append(solution)

    # ─── DYNAMIC DATA EXTRACTION ───
    rpt_indices = [5]  # First RPT is always cycle 5
    current_idx = 5

    for _ in range(chunks):
        current_idx += 101
        rpt_indices.append(current_idx)
    if remainder > 0:
        current_idx += remainder + 1
        rpt_indices.append(current_idx)

    rpt_capacities = []
    throughput_for_rpt = []

    for i in rpt_indices:
        rpt_cycle_data = solution.cycles[i]

        # CRITICAL FIX: Capacity measurement is now at step 2, not step 3.
        cap = rpt_cycle_data.steps[2]["Discharge capacity [A.h]"].entries
        true_cap = cap[-1] - cap[0]  # Drift correction
        tp = rpt_cycle_data["Throughput capacity [A.h]"].entries[-1] / 1000  # Convert to kA.h

        rpt_capacities.append(true_cap)
        throughput_for_rpt.append(tp)

    soh_rpt = [(cap1 / rpt_capacities[0]) * 100 for cap1 in rpt_capacities]

    # Shift the throughput so the graph starts exactly at 0 for the first RPT
    tp_offset = throughput_for_rpt[0]
    throughput_shifted = [t - tp_offset for t in throughput_for_rpt]

    all_rpt_capacities.append(rpt_capacities)
    all_throughput_lists.append(throughput_shifted)
    all_soh_lists.append(soh_rpt)
    all_cycle_lists.append(rpt_indices)

    print(f"\n=== {c_rate}C RESULTS ===")
    print("RPT SoH [%]:", [f"{s:.2f}" for s in soh_rpt])

    aging_idx_BoL = rpt_indices[0] - 1
    aging_idx_EoL = rpt_indices[-1] - 1

    cyc_BoL = solution.cycles[aging_idx_BoL]
    cyc_EoL = solution.cycles[aging_idx_EoL]

    por_xavg_BoL_list.append(cyc_BoL["X-averaged negative electrode porosity"].entries)
    por_xavg_EoL_list.append(cyc_EoL["X-averaged negative electrode porosity"].entries)

    tp_BoL_raw = cyc_BoL["Throughput capacity [A.h]"].entries
    tp_EoL_raw = cyc_EoL["Throughput capacity [A.h]"].entries

    tp_BoL_list.append(tp_BoL_raw - tp_BoL_raw[0])
    tp_EoL_list.append(tp_EoL_raw - tp_EoL_raw[0])

    # Extract EoL metrics
    cyc_rpt_eol = solution.cycles[-1]

    LAM_neg.append(cyc_rpt_eol["Loss of active material in negative electrode [%]"].entries[-1])
    LAM_pos.append(cyc_rpt_eol["Loss of active material in positive electrode [%]"].entries[-1])
    LLI.append(cyc_rpt_eol["Loss of lithium inventory [%]"].entries[-1])

    vol_gr = solution["X-averaged negative electrode primary active material volume fraction"].entries
    vol_si = solution["X-averaged negative electrode secondary active material volume fraction"].entries

    lam_gr.append(((vol_gr[0] - vol_gr[-1]) / vol_gr[0]) * 100)
    lam_si.append(((vol_si[0] - vol_si[-1]) / vol_si[0]) * 100)

    # ─── SPATIAL DATA EXTRACTION ───
    cyc_aging = solution.cycles[-2]

    # Shift the throughput array so it fits inside the [0, 3] plot boundaries
    tp_raw = cyc_aging["Throughput capacity [A.h]"].entries
    tp_shifted = tp_raw - tp_raw[0]
    tp_list.append(tp_shifted)

    Rs = parameter_values["Secondary: Negative particle radius [m]"]
    Rp = parameter_values["Primary: Negative particle radius [m]"]

    disp_Si = cyc_aging["X-averaged negative secondary particle surface displacement [m]"].entries + Rs
    disp_Gr = cyc_aging["X-averaged negative primary particle surface displacement [m]"].entries + Rp

    Vsi_pct = 3 * (disp_Si - Rs) / Rs * 100
    Vgr_pct = 3 * (disp_Gr - Rp) / Rp * 100

    Vsi_pct_list.append(Vsi_pct)
    Vgr_pct_list.append(Vgr_pct)
    disp_Si_list.append(disp_Si)
    disp_Gr_list.append(disp_Gr)

    # ─── CONTINUOUS DEGRADATION EXTRACTION ───
    cont_tp_list.append(solution["Throughput capacity [A.h]"].entries)
    cont_lli_list.append(solution["Loss of lithium inventory [%]"].entries)
    cont_lam_neg_list.append(solution["Loss of active material in negative electrode [%]"].entries)
    cont_lam_pos_list.append(solution["Loss of active material in positive electrode [%]"].entries)

    vol_gr_cont = solution["X-averaged negative electrode primary active material volume fraction"].entries
    vol_si_cont = solution["X-averaged negative electrode secondary active material volume fraction"].entries
    cont_lam_gr_list.append(((vol_gr_cont[0] - vol_gr_cont) / vol_gr_cont[0]) * 100)
    cont_lam_si_list.append(((vol_si_cont[0] - vol_si_cont) / vol_si_cont[0]) * 100)


